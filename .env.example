# =============================================================================
# CloverBot Configuration
# Copy this file to .env and fill in your values
# =============================================================================

# --- LLM Provider ---
# Options: "openai" or "ollama"
LLM_PROVIDER=openai

# --- OpenAI Settings (used when LLM_PROVIDER=openai) ---
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# --- Ollama Settings (used when LLM_PROVIDER=ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1

# --- Server Settings ---
HOST=0.0.0.0
PORT=8400
# Comma-separated list of allowed origins for CORS (your website domain)
ALLOWED_ORIGINS=https://myclover.tech,http://localhost:3000

# --- Slack Escalation ---
# Create a Slack incoming webhook for #clover-ai-development or a support channel
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# --- RAG Settings ---
# Directory containing your product docs (.txt, .md files)
KNOWLEDGE_DIR=./knowledge
# ChromaDB persistence directory
CHROMA_DIR=./chroma_db
# Embedding model (runs locally via sentence-transformers)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# --- Security ---
# Rate limit: max messages per IP per minute
RATE_LIMIT_PER_MINUTE=10
# Session timeout in minutes
SESSION_TIMEOUT_MINUTES=30

# --- Lead Capture ---
# Set to "true" to require name/email before chat
REQUIRE_LEAD_INFO=false
